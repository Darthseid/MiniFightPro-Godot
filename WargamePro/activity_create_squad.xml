<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText
            android:id="@+id/unitNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/unit_name_hint"
            android:inputType="text"
            android:autofillHints="unitName" />

        <Button
            android:id="@+id/unitTypeButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/select_squad_types" />


        <EditText
            android:id="@+id/movementInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/enter_movement_in_inches"
            android:autofillHints="🏃‍♀️"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/hardnessInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/toughness_hint"
            android:inputType="number"
            android:autofillHints="🪨" />

        <EditText
            android:id="@+id/DefenseInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/armor_save_hint"
            android:inputType="number"
            android:autofillHints="🛡️" />

        <EditText
            android:id="@+id/DodgeInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/invulnerable_save_hint"
            android:inputType="number"
            android:autofillHints="🔮" />

        <EditText
            android:id="@+id/damageResistanceInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/feel_no_pain_hint"
            android:inputType="number"
            android:autofillHints="➗" />

        <EditText
            android:id="@+id/braveryInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/leadership_hint"
            android:inputType="number"
            android:autofillHints="🏳️" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/available_models"
            android:layout_marginTop="16dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/availableModelsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/selected_models"
            android:layout_marginTop="16dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/selectedModelsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/selectAbilitiesButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/select_unit_abilities" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/discardButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/discard" />

            <Button
                android:id="@+id/saveButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/save" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
