<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/root_layout"
    android:background="@drawable/battlebackground">
    <!-- Distance Display -->
    <TextView
        android:id="@+id/distance_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:padding="16dp"
        android:textSize="16sp"
        android:textColor="#000000"
        android:background="#FFFFFF"
        android:text="@string/distance_between_units" />
    <!-- Next Phase Button (➡️ Emoji) -->
    <Button
        android:id="@+id/next_phase_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="1dp"
        android:background="@android:color/transparent"
        android:text="➡️"
        android:textSize="24sp"
        android:textColor="@android:color/black"
        android:padding="1dp"/>
    <!-- Orders Menu (Hidden Bottom Panel) -->
    <LinearLayout
        android:id="@+id/orders_menu"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:translationY="300dp"> <!-- Initially Hidden -->
        <!-- Order Points Display -->
        <TextView
            android:id="@+id/order_points_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Order Points: 10"
            android:textSize="18sp"
            android:textColor="@android:color/black"
            android:layout_gravity="center_horizontal"
            android:paddingBottom="10dp"/>
        <!-- Placeholder Orders -->
        <Button
            android:id="@+id/order1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎖️ Use Tactical Genius (2 Points)" />
        <Button
            android:id="@+id/order2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚀 Use Rapid Deployment (3 Points)" />
        <Button
            android:id="@+id/order3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🦾 Use Veteran Tactician (5 Points)" />
    </LinearLayout>
    <TextView
        android:id="@+id/order_drag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:text="⬆️" android:textSize="30sp" />
</FrameLayout>
