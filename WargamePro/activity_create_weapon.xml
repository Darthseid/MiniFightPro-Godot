<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".CreateWeaponActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Weapon Name -->
        <EditText
            android:id="@+id/weaponNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/weapon_name_hint"
            android:inputType="text"
            android:autofillHints="weaponName" />

        <!-- Weapon Range -->
        <EditText
            android:id="@+id/weaponRangeInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/weapon_range_hint"
            android:inputType="numberDecimal"
            android:autofillHints="range" />

        <!-- Weapon Attacks -->
        <EditText
            android:id="@+id/weaponAttacksInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/weapon_attacks_hint"
            android:inputType="text"
            android:autofillHints="attacks" />

        <!-- Weapon Hit Skill -->
        <EditText
            android:id="@+id/weaponHitSkillInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/weapon_hit_skill_hint"
            android:inputType="number"
            android:autofillHints="hitSkill" />

        <!-- Weapon Strength -->
        <EditText
            android:id="@+id/weaponStrengthInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/weapon_strength_hint"
            android:inputType="number"
            android:autofillHints="strength" />

        <!-- Weapon Armor Penetration -->
        <EditText
            android:id="@+id/weaponArmorPenInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/weapon_armor_pen_hint"
            android:inputType="numberSigned"
            android:autofillHints="armorPenetration" />

        <!-- Weapon Damage -->
        <EditText
            android:id="@+id/weaponDamageInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/weapon_damage_hint"
            android:inputType="text"
            android:autofillHints="damage" />

        <!-- Button to Open Abilities Modal -->
        <Button
            android:id="@+id/selectAbilitiesButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/select_weapon_abilities" />

        <!-- Save and Discard Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/discardButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/discard" />

            <Button
                android:id="@+id/saveButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/save" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
